{
  "name": "e-service-design-system",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npx sass ./src/scss:./dist/css",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-scss": "node --experimental-json-modules scripts/generateScssFiles.js && npx prettier src/scss/*.scss --write",
    "build-scss": "npm run generate-scss && npm run build",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "@storybook/addon-a11y": "^7.2.2",
    "@storybook/addon-essentials": "^7.4.1",
    "@storybook/addon-interactions": "^7.2.2",
    "@storybook/addon-links": "^7.2.2",
    "@storybook/blocks": "^7.2.2",
    "@storybook/html": "^7.2.2",
    "@storybook/html-vite": "^7.2.2",
    "@storybook/testing-library": "^0.2.0",
    "@types/pretty": "^2.0.2",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "clsx": "^1.2.1",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-storybook": "^0.6.13",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup-plugin-scss": "^4.0.0",
    "sass": "^1.63.6",
    "storybook": "^7.2.2",
    "stylelint": "^15.10.2",
    "stylelint-config-standard-scss": "^10.0.0",
    "stylelint-prettier": "^4.0.0",
    "stylelint-selector-bem-pattern": "^3.0.0",
    "typescript": "^5.0.2",
    "vite": "^4.3.9"
  },
  "repository": {
    "type": "git",
    "url": "https://koodivaramu.eesti.ee/veebiraamistik/e-service-design-system.git"
  },
  "files": [
    "/dist/*/**"
  ],
  "dependencies": {
    "pretty": "^2.0.0"
  }
}
